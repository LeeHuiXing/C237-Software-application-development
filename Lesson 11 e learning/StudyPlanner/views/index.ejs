<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <link rel="stylesheet" href="/css/style.css">
    <title>Study Planner</title>
</head>

<body>
    <%- include('partials/navbar.ejs') %>

    <div class="container mt-4">

        <h2 class="text-center fw-bold mb-4">My Study Planner</h2>

        <!-- Stats Section -->
        <div class="row text-center mb-4">
            <div class="col-md-4">
                <div class="card shadow-sm p-3">
                    <h6 class="fw-bold text-muted">Total Sessions</h6>
                    <h3 class="text-primary fw-bold"><%= sessions.length %></h3>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card shadow-sm p-3">
                    <h6 class="fw-bold text-muted">Completed</h6>
                    <h3 class="text-success fw-bold"><%= sessions.filter(s => s.status === 'Completed').length %></h3>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card shadow-sm p-3">
                    <h6 class="fw-bold text-muted">Pending</h6>
                    <h3 class="text-danger fw-bold"><%= sessions.filter(s => s.status === 'Pending').length %></h3>
                </div>
            </div>
        </div>

        <!-- Search -->
        <form class="d-flex mb-3" action="/" method="GET">
            <input class="form-control me-2" type="search" name="search"
                placeholder="Search subject, topic, or status"
                value="<%= search || '' %>">
            <button class="btn btn-primary" type="submit">Search</button>
        </form>

        <!-- Table -->
        <table class="table table-hover align-middle">
            <thead class="study-header">
                <tr>
                    <th>ID</th>
                    <th>Subject</th>
                    <th>Topic</th>
                    <th>Duration</th>
                    <th>Status</th>
                    <th>Comment</th>
                    <th>Details</th>
                    <th>Edit</th>
                    <th>Delete</th>
                </tr>
            </thead>

            <tbody>
                <% if (sessions.length === 0) { %>
                    <tr>
                        <td colspan="9" class="text-center text-muted">No study sessions found.</td>
                    </tr>
                <% } %>

                <% for (let i = 0; i < sessions.length; i++) { %>
                    <tr>
                        <td><%= sessions[i].id %></td>
                        <td><%= sessions[i].subject %></td>
                        <td><%= sessions[i].topic %></td>
                        <td><%= sessions[i].duration %></td>
                        <td>
                            <span class="badge <%= sessions[i].status === 'Completed' ? 'bg-success' : 'bg-warning text-dark' %>">
                                <%= sessions[i].status %>
                            </span>
                        </td>
                        <td><%= sessions[i].comment %></td>
                        <td>
                            <a class="btn btn-sm btn-outline-primary" href="/sessions/<%= sessions[i].id %>">View</a>
                        </td>
                        <td>
                            <a class="btn btn-sm btn-outline-success" href="/sessions/<%= sessions[i].id %>/edit">Edit</a>
                        </td>
                        <td>
                            <a class="btn btn-sm btn-outline-danger" href="/sessions/<%= sessions[i].id %>/delete">Delete</a>
                        </td>
                    </tr>
                <% } %>
            </tbody>
        </table>

    </div>
</body>
</html>
