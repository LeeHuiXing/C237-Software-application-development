<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <link rel="stylesheet" href="/css/style.css">
    <title>Study Planner</title>
</head>

<body>
    <%- include('partials/navbar.ejs') %>

    <div class="container mt-4 bg-white p-4 rounded shadow">

        <h2 class="text-center fw-bold text-success mb-4">Edit Study Session</h2>

        <form action="/sessions/<%= editSession.id %>/edit" method="POST">

            <div class="mb-3">
                <label for="subject" class="form-label fw-bold">Subject:</label>
                <input type="text" class="form-control" id="subject" name="subject" value="<%= editSession.subject %>" required>
            </div>

            <div class="mb-3">
                <label for="topic" class="form-label fw-bold">Topic:</label>
                <input type="text" class="form-control" id="topic" name="topic" value="<%= editSession.topic %>" required>
            </div>

            <div class="mb-3">
                <label for="duration" class="form-label fw-bold">Duration:</label>
                <select class="form-control" id="duration" name="duration" required>
                    <option value="30 minutes" <%= editSession.duration === '30 minutes' ? 'selected' : '' %>>30 minutes</option>
                    <option value="1 hour" <%= editSession.duration === '1 hour' ? 'selected' : '' %>>1 hour</option>
                    <option value="1.5 hours" <%= editSession.duration === '1.5 hours' ? 'selected' : '' %>>1.5 hours</option>
                    <option value="2 hours" <%= editSession.duration === '2 hours' ? 'selected' : '' %>>2 hours</option>
                    <option value="2.5 hours" <%= editSession.duration === '2.5 hours' ? 'selected' : '' %>>2.5 hours</option>
                    <option value="3 hours" <%= editSession.duration === '3 hours' ? 'selected' : '' %>>3 hours</option>
                </select>
            </div>

            <div class="mb-3">
                <label for="status" class="form-label fw-bold">Status:</label>
                <select class="form-control" id="status" name="status" required>
                    <option value="Pending" <%= editSession.status === 'Pending' ? 'selected' : '' %>>Pending</option>
                    <option value="Completed" <%= editSession.status === 'Completed' ? 'selected' : '' %>>Completed</option>
                </select>
            </div>

            <div class="mb-3">
                <label for="comment" class="form-label fw-bold">Comment:</label>
                <textarea class="form-control" id="comment" rows="3" name="comment"><%= editSession.comment %></textarea>
            </div>

            <button type="submit" class="btn btn-success fw-bold">Submit</button>

        </form>

    </div>
</body>
</html>
