<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <link rel="stylesheet" href="/css/style.css">
    <title>Study Planner</title>
</head>

<body>
    <%- include('partials/navbar.ejs') %>

    <div class="container mt-4">

        <h2 class="text-center fw-bold text-primary mb-4">Session Details</h2>

        <div class="card shadow-sm mb-3">
            <div class="card-body">
                <h6 class="fw-bold">Subject</h6>
                <p class="mb-0"><%= session.subject %></p>
            </div>
        </div>

        <div class="card shadow-sm mb-3">
            <div class="card-body">
                <h6 class="fw-bold">Topic</h6>
                <p class="mb-0"><%= session.topic %></p>
            </div>
        </div>

        <div class="card shadow-sm mb-3">
            <div class="card-body">
                <h6 class="fw-bold">Duration</h6>
                <p class="mb-0"><%= session.duration %></p>
            </div>
        </div>

        <div class="card shadow-sm mb-3">
            <div class="card-body">
                <h6 class="fw-bold">Status</h6>
                <p class="mb-0">
                    <span class="badge <%= session.status === 'Completed' ? 'bg-success' : 'bg-warning text-dark' %>">
                        <%= session.status %>
                    </span>
                </p>
            </div>
        </div>

        <div class="card shadow-sm mb-3">
            <div class="card-body">
                <h6 class="fw-bold">Comment</h6>
                <p class="mb-0"><%= session.comment %></p>
            </div>
        </div>

        <a class="btn btn-secondary" href="/">Back</a>

    </div>
</body>
</html>
